<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>PLG_SYSTEM_IMAGEKIT</name>
    <author>Hans Kuijpers</author>
    <authorEmail>hans2103@gmail.com</authorEmail>
    <creationDate>February 2026</creationDate>
    <copyright>(C) 2026 Hans Kuijpers. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <version>26.19.02</version>
    <compatibleversions>
        <version type="platform">6.*</version>
    </compatibleversions>
    <description>PLG_SYSTEM_IMAGEKIT_XML_DESCRIPTION</description>

    <namespace path="src">Hans2103\Plugin\System\ImageKit</namespace>

    <files>
        <filename plugin="imagekit">imagekit.php</filename>
        <folder>services</folder>
        <folder>src</folder>
        <folder>language</folder>
    </files>

    <languages>
        <language tag="en-GB">language/en-GB/plg_system_imagekit.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_imagekit.sys.ini</language>
    </languages>

    <updateservers>
        <server type="extension" name="System - ImageKit">https://raw.githubusercontent.com/hans2103/plg_system_imagekit/main/update.xml</server>
    </updateservers>

    <config>
        <fields name="params" addfieldprefix="Hans2103\Plugin\System\ImageKit\Field">

            <!-- ============================================================
                 Connection
                 ============================================================ -->
            <fieldset name="basic" label="PLG_SYSTEM_IMAGEKIT_FIELDSET_BASIC">

                <field
                    name="url_endpoint"
                    type="url"
                    label="PLG_SYSTEM_IMAGEKIT_URL_ENDPOINT_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_URL_ENDPOINT_DESC"
                    default="https://ik.imagekit.io/momentsuntil"
                    filter="url"
                    required="true"
                    size="60"
                />

                <field
                    name="public_key"
                    type="text"
                    label="PLG_SYSTEM_IMAGEKIT_PUBLIC_KEY_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_PUBLIC_KEY_DESC"
                    default=""
                    size="60"
                />

                <field
                    name="private_key"
                    type="password"
                    label="PLG_SYSTEM_IMAGEKIT_PRIVATE_KEY_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_PRIVATE_KEY_DESC"
                    default=""
                    size="60"
                />

            </fieldset>

            <!-- ============================================================
                 Default image settings
                 ============================================================ -->
            <fieldset name="transform" label="PLG_SYSTEM_IMAGEKIT_FIELDSET_TRANSFORM">

                <field
                    name="quality"
                    type="number"
                    label="PLG_SYSTEM_IMAGEKIT_QUALITY_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_QUALITY_DESC"
                    default="80"
                    min="1"
                    max="100"
                    step="1"
                    filter="integer"
                />

                <field
                    name="srcset_widths"
                    type="text"
                    label="PLG_SYSTEM_IMAGEKIT_SRCSET_WIDTHS_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_SRCSET_WIDTHS_DESC"
                    default="320,480,768,1024,1280,1600"
                    filter="string"
                    size="40"
                />

                <field
                    name="default_sizes"
                    type="text"
                    label="PLG_SYSTEM_IMAGEKIT_DEFAULT_SIZES_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_DEFAULT_SIZES_DESC"
                    default="100vw"
                    filter="string"
                    size="60"
                />

                <field
                    name="extra_transformations"
                    type="text"
                    label="PLG_SYSTEM_IMAGEKIT_EXTRA_TRANSFORMATIONS_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_EXTRA_TRANSFORMATIONS_DESC"
                    default=""
                    filter="string"
                    size="60"
                />

                <field
                    name="strip_size_suffix"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_IMAGEKIT_STRIP_SIZE_SUFFIX_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_STRIP_SIZE_SUFFIX_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

            </fieldset>

            <!-- ============================================================
                 Delivery toggles
                 ============================================================ -->
            <fieldset name="delivery" label="PLG_SYSTEM_IMAGEKIT_FIELDSET_DELIVERY">

                <field
                    name="enable_image_delivery"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_IMAGEKIT_ENABLE_IMAGE_DELIVERY_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_ENABLE_IMAGE_DELIVERY_DESC"
                    default="1"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="enable_video_delivery"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_IMAGEKIT_ENABLE_VIDEO_DELIVERY_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_ENABLE_VIDEO_DELIVERY_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="reject_paths"
                    type="textarea"
                    label="PLG_SYSTEM_IMAGEKIT_REJECT_PATHS_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_REJECT_PATHS_DESC"
                    default=""
                    filter="raw"
                    rows="6"
                    cols="60"
                />

            </fieldset>

            <!-- ============================================================
                 Asset (CSS / JS / fonts) delivery
                 ============================================================ -->
            <fieldset name="assets" label="PLG_SYSTEM_IMAGEKIT_FIELDSET_ASSETS">

                <field
                    name="note_assets_intro"
                    type="note"
                    label="PLG_SYSTEM_IMAGEKIT_NOTE_ASSETS_INTRO_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_NOTE_ASSETS_INTRO_DESC"
                    class="alert alert-warning"
                />

                <field
                    name="enable_template_assets"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_IMAGEKIT_ENABLE_TEMPLATE_ASSETS_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_ENABLE_TEMPLATE_ASSETS_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="enable_extension_assets"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_IMAGEKIT_ENABLE_EXTENSION_ASSETS_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_ENABLE_EXTENSION_ASSETS_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="enable_core_assets"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_IMAGEKIT_ENABLE_CORE_ASSETS_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_ENABLE_CORE_ASSETS_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

            </fieldset>

            <!-- ============================================================
                 Per-image overrides & CSS backgrounds
                 ============================================================ -->
            <fieldset name="usage" label="PLG_SYSTEM_IMAGEKIT_FIELDSET_USAGE">

                <field
                    name="note_srcset_override"
                    type="note"
                    label="PLG_SYSTEM_IMAGEKIT_NOTE_SRCSET_OVERRIDE_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_NOTE_SRCSET_OVERRIDE_DESC"
                    class="alert alert-info"
                />

                <field
                    name="note_sizes_override"
                    type="note"
                    label="PLG_SYSTEM_IMAGEKIT_NOTE_SIZES_OVERRIDE_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_NOTE_SIZES_OVERRIDE_DESC"
                    class="alert alert-info"
                />

                <field
                    name="note_skip_attr"
                    type="note"
                    label="PLG_SYSTEM_IMAGEKIT_NOTE_SKIP_ATTR_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_NOTE_SKIP_ATTR_DESC"
                    class="alert alert-info"
                />

                <field
                    name="note_css_bg"
                    type="note"
                    label="PLG_SYSTEM_IMAGEKIT_NOTE_CSS_BG_LABEL"
                    description="PLG_SYSTEM_IMAGEKIT_NOTE_CSS_BG_DESC"
                    class="alert alert-info"
                />

            </fieldset>

            <!-- ============================================================
                 System status / diagnostics
                 ============================================================ -->
            <fieldset name="status" label="PLG_SYSTEM_IMAGEKIT_FIELDSET_STATUS">

                <field
                    name="status_panel"
                    type="status"
                    label=""
                />

            </fieldset>

        </fields>
    </config>
</extension>
